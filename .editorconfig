root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[{Makefile,*.mk}]
indent_style = tab

[.meta/schemas/*.schema.json]
insert_final_newline = true

[*.html]
insert_final_newline = false

[**/layouts/**/*.html]
insert_final_newline = true

[.git*]
indent_style = tab

[*.scss]
insert_final_newline = unset

## generated/external content

[.styles/**/*.{json,yml}]
insert_final_newline = unset
indent_style = unset
indent_size = unset

[{data/**/*.json,.meta/pkgs/**/package.json}]
insert_final_newline = unset

[themes/pico/assets/css/pico/*]
insert_final_newline = unset
indent_style = unset
indent_size = unset

## binary content

[static/.well-known/openpgpkey/*/hu/*]
end_of_line = unset
indent_size = unset
indent_style = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

## formatted by external tools (e.g. treefmt, golangci-lint, etc)
[*.{go,md,nix,yaml,yml}]
end_of_line = unset
indent_size = unset
indent_style = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
